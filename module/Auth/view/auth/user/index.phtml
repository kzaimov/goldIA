<?php
/** @var Laminas\View\Renderer\PhpRenderer $this */
$users = $this->users ?? [];
?>
<div class="ui container">
    <h2 class="ui header">User Management</h2>
    <a class="ui primary button" href="<?= $this->url('admin-users/add') ?>">Add User</a>
    <table class="ui celled table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
                <th>Created</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <?php foreach ($users as $user): ?>
                <tr>
                    <td><?= (int) $user['id'] ?></td>
                    <td><?= $this->escapeHtml($user['username']) ?></td>
                    <td><?= $this->escapeHtml($user['email']) ?></td>
                    <td><?= $this->escapeHtml($user['role']) ?></td>
                    <td><?= $this->escapeHtml((string) $user['created_at']) ?></td>
                    <td>
                        <a class="ui red mini button" href="<?= $this->url('admin-users/delete', ['id' => (int) $user['id']]) ?>">Delete</a>
                    </td>
                </tr>
            <?php endforeach; ?>
        </tbody>
    </table>
</div>
